{
  "name": "@hmcts-cft/express-govuk-starter",
  "version": "0.1.1",
  "description": "GOV.UK Frontend integration for Express 5 — Nunjucks, Helmet CSP, i18n, cookie consent, and error handlers with sensible defaults.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hmcts/expressjs-monorepo-template.git",
    "directory": "libs/express-govuk-starter"
  },
  "homepage": "https://github.com/hmcts/expressjs-monorepo-template/tree/master/libs/express-govuk-starter#readme",
  "bugs": "https://github.com/hmcts/expressjs-monorepo-template/issues",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://pkgs.dev.azure.com/hmcts/Artifacts/_packaging/hmcts-lib/npm/registry/"
  },
  "scripts": {
    "build": "tsc && cp -r src/govuk-frontend/views dist/govuk-frontend/ && cp -r src/cookies/views dist/cookies/",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "peerDependencies": {
    "@hmcts/cookie-manager": "^1.1.0",
    "express": "^5.1.0",
    "govuk-frontend": "^6.0.0",
    "helmet": "^8.0.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/nunjucks": "3.2.6"
  }
}
